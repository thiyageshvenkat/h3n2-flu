# Optional runtime secrets
# Source this file before running Nextflow, or export the variables manually.

export AZURE_BATCH_KEY=your-batch-key
export AZURE_STORAGE_NAME=your-storage-account-name
export AZURE_STORAGE_KEY=your-storage-account-key
export SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0
